{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.fewsats.com/$1",
      "has": [{ "type": "host", "value": "fewsats.com" }],
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/:slug", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
} 